{
  "expo": {
    "name": "MyDiri",
    "slug": "mydiri",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icono.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icono.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.exodo.diris",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.exodo.diris",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icono.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "name": "MyDiri",
      "shortName": "MyDiri",
      "favicon": "./assets/icono.png",
      "backgroundColor": "#ffffff",
      "themeColor": "#ffffff",
      "display": "standalone",
      "icons": [
        {
          "src": "./assets/icon-512.png",
          "sizes": "512x512",
          "type": "image/png",
          "purpose": "any"
        },
        {
          "src": "./assets/icon-maskable.png",
          "sizes": "1024x1024",
          "type": "image/png",
          "purpose": "any maskable"
        }
      ]
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "74f86b79-7475-4aa0-8400-9c6253e2095e"
      }
    },
    "owner": "jesussanto"
  }
}
