{
  "expo": {
    "name": "MyDiri",
    "slug": "mydiri",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/Icono.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/Icono.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.exodo.diris",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.exodo.diris",
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/Icono.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/Icono.png",
      "name": "MyDiri",
      "shortName": "MyDiri",  
      "backgroundColor": "#ffffff",
      "themeColor": "#ffffff",
      "display": "standalone"
    },
    "plugins": [
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "eas": {
        "projectId": "74f86b79-7475-4aa0-8400-9c6253e2095e"
      }
    },
    "owner": "jesussanto"
  }
}